# =============================================================================
# proj_ontology — configuration template
# Copy to .env and edit. Documentation:
#   Documentation index:               docs/README.md
#   Root README (setup, overview):     README.md
#   v1 Topological Manifold theory:       docs/v1-topological-manifold/README.md
#   v2 Latent Semantic Attractor Graph:   docs/v2-latent-semantic-attractor-graph/README.md
#   v1 entry:                         python -m v1_single_pass.main
#   v2 entry:                         python -m v2_orchestrator.main
#   Neo4j exploration queries:         docs/cypher/queries/README.md
# =============================================================================

# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
# Use a dedicated DB per pipeline stage (switch before each run).
# Names must be simple ASCII (no underscores). Examples:
#   Topological Manifold:              NEO4J_DATABASE=ontologyv1
#   Latent Semantic Attractor Graph:   NEO4J_DATABASE=ontologyv2
NEO4J_DATABASE=ontologyv2
NEO4J_DELETE_BATCH_SIZE=10000
NEO4J_LOAD_BATCH_SIZE=5000

# Optional Cypher directory overrides
# V1_CYPHER_DIR=v1_single_pass/cypher
# V2_CYPHER_DIR=v2_orchestrator/cypher

# Embedding pipeline (shared model under models/)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# Hugging Face Hub token (higher rate limits; create at https://huggingface.co/settings/tokens)
HF_TOKEN=
CHUNK_SIZE=1024
CHUNK_OVERLAP=128
EMBED_BATCH_SIZE=64

# Ontology extraction (shared)
CONCEPTS_PER_CHUNK=2
# Top-k before mutual filter; Latent Semantic Attractor Graph mutual k-NN needs a wider net (7 → ~4–5 avg degree)
RELATED_TO_PEER_COUNT=7  # shared default; v2 mutual k-NN benefits from a wider net
RELATED_TO_MIN_WEIGHT=0.15
MAX_CONCEPT_COUNT=200
DICTIONARY_K_MIN=20
DICTIONARY_K_STEP=20
RECONSTRUCTION_ERROR_TOLERANCE=0.015
DEAD_CONCEPT_PENALTY=0.05
MAX_DEAD_CONCEPT_RATIO=0.25
DICTIONARY_BATCH_SIZE=256
RANDOM_SEED=42

# Topological Manifold only — Louvain L1 super-concepts (python -m v1_single_pass.main)
LOUVAIN_RESOLUTION=1.0

# Latent Semantic Attractor Graph streaming (python -m v2_orchestrator.main)
ARTICLES_PER_BATCH=2
CENTROID_ALPHA=0.05
TOP_K_ASSIGN=2
MIXTURE_RATIO=0.90
ADAPTIVE_PERCENTILE=85
MIN_ASSIGN_THRESHOLD=0.30
MAX_ASSIGN_THRESHOLD=0.45
# OMP atoms are near-orthogonal — 0 soft_merged per batch is normal and healthy.
SOFT_MERGE_LOW=0.55
ORPHAN_BUFFER_MIN_FACTOR=3
KEEP_VISUAL_ARTIFACTS=true

# Wikipedia ingestion
WIKIPEDIA_MAX_RETRIES=3
WIKIPEDIA_REQUEST_DELAY_SECONDS=1.5
WIKIPEDIA_USER_AGENT=proj-ontology/2.0 (+https://github.com/YOUR_ORG/proj_ontology; contact@example.com)

# Topological Manifold cache filenames (under v1_single_pass/data/cache/)
DOCS_CACHE_FILE=wikipedia_docs.json
CHUNKS_CACHE_FILE=chunks.json
EMBEDDINGS_CACHE_FILE=embeddings.npy
EMBED_MANIFEST_FILE=embed_manifest.json

# Sphere plot — `python -m v1_single_pass.visualisation.plot_ontology_sphere`
DRAW_EDGES=true
EDGE_AUTO_DISABLE_CHUNK_THRESHOLD=5000
