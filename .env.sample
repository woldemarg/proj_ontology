# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=ontology
NEO4J_DELETE_BATCH_SIZE=10000
NEO4J_LOAD_BATCH_SIZE=5000

# Optional override for external Cypher directory
# ONTOLOGY_CYPHER_DIR=script/cypher

# Embedding pipeline
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
CHUNK_SIZE=1024
CHUNK_OVERLAP=128
EMBED_BATCH_SIZE=64

# Ontology extraction
CONCEPTS_PER_CHUNK=2
RELATED_TO_PEER_COUNT=5
RELATED_TO_MIN_WEIGHT=0.15
MAX_CONCEPT_COUNT=200
DICTIONARY_K_MIN=20
DICTIONARY_K_STEP=20
RECONSTRUCTION_ERROR_TOLERANCE=0.015
DEAD_CONCEPT_PENALTY=0.05
MAX_DEAD_CONCEPT_RATIO=0.25
DICTIONARY_BATCH_SIZE=256
LOUVAIN_RESOLUTION=1.0
RANDOM_SEED=42

# Wikipedia ingestion
WIKIPEDIA_MAX_RETRIES=3
WIKIPEDIA_REQUEST_DELAY_SECONDS=1.5
WIKIPEDIA_USER_AGENT=proj-ontology/1.0 (ontology research POC; set your repo URL here)

# Cache filenames (under data/cache/)
DOCS_CACHE_FILE=wikipedia_docs.json
CHUNKS_CACHE_FILE=chunks.json
EMBEDDINGS_CACHE_FILE=embeddings.npy
EMBED_MANIFEST_FILE=embed_manifest.json

# Visualisation (optional; requires script/visualisation/)
# KEEP_VISUAL_ARTIFACTS writes L0 arrays to data/visualisation/artifacts/
KEEP_VISUAL_ARTIFACTS=false
DRAW_EDGES=true
EDGE_AUTO_DISABLE_CHUNK_THRESHOLD=5000
