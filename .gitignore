# Secrets and local config
.env
.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
env/

# IDE / editor
.idea/
.vscode/
.spyproject/
*.swp
*.swo

# Pipeline artifacts (rebuilt on first run)
data/cache/*
