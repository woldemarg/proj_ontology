.ipynb_checkpoints/

# Ad-hoc plot exports
iframe_figures/

# Local visualisation outputs (rebuilt when KEEP_VISUAL_ARTIFACTS=true)
data/visualisation/artifacts/*
!data/visualisation/artifacts/.gitkeep
data/visualisation/*.html

# Local experiments (not part of published repo)
_odds/
